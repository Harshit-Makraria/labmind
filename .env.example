# ─── LLM Provider (provider-agnostic, read server-side by the Route Handlers) ──
# LLM_PROVIDER selects the active adapter: "demo" | "openai" | "azure" | "claude"
# "demo" (the default) needs NO API key and returns deterministic, realistic
# responses — perfect for the jury and for a zero-config Vercel deploy.
LLM_PROVIDER=demo

# Master demo switch. When true (default) every AI tool returns deterministic data
# regardless of provider, and the DEMO MODE badge shows in the corner.
DEMO_MODE=true

# Instructor dashboard passcode (default below).
INSTRUCTOR_PASSCODE=labmind2026

# ─── Optional: real LLM providers (only used when DEMO_MODE=false) ─────────────
# Standard OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Azure OpenAI (GPT-4o)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# NOTE: There is NO separate backend URL to configure. The API ships inside this
# Next.js app as Route Handlers (/api/*), so it is same-origin on Vercel.
